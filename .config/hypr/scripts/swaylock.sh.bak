#!/bin/sh

swaylock \
--daemonize \
--screenshots \
--clock \
--indicator \
--indicator-radius 100 \
--indicator-thickness 7 \
--effect-blur 7x5 \
--effect-vignette 0.5:0.5 \
--ring-color 231d2d \
--key-hl-color 694A5D \
--line-color 0C0A0F \
--inside-color 0C0A0F \
--separator-color 0C0A0F \
--text-color d8c3c8 \
--line-clear-color 694A5D \
--ring-clear-color d8c3c8 \
--inside-clear-color 231d2d \
--line-clear-color 231d2d \
--text-clear-color d8c3c8 \
--ring-wrong-color 995369 \
--inside-wrong-color 0C0A0F \
--text-wrong-color 995369 \
--grace 0 \
--font 'ShureTechMono Nerd Font Mono' \
--fade-in 0.2
