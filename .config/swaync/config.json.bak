{
	"$schema": "/etc/xdg/swaync/configSchema.json",
	"positionX": "left",
	"positionY": "top",
	"layer": "overlay",
	"control-center-layer": "overlay",
	"layer-shell": true,
	"cssPriority": "application",
	"control-center-margin-top": 16,
	"control-center-margin-bottom": 16,
	"control-center-margin-right": 0,
	"control-center-margin-left": 16,
	"notification-2fa-action": false,
	"notification-inline-replies": true,
	"notification-icon-size": 64,
	"notification-body-image-height": 200,
	"notification-body-image-width": 200,
	"timeout": 10,
	"timeout-low": 5,
	"timeout-critical": 0,
	"fit-to-screen": true,
	"control-center-width": 500,
	"control-center-height": 800,
	"notification-window-width": 400,
	"keyboard-shortcuts": true,
	"image-visibility": "when-available",
	"transition-time": 200,
	"hide-on-clear": false,
	"hide-on-action": true,
	"script-fail-notify": true,
	"scripts": {
		"ignore_spotify": {
		    "exec": "",
			"urgency": "Normal"
		},
		"ignore_spotify": {
		    "exec": "",
			"urgency": "Normal"
		},
		"ignore_mpd": {
		    "exec": "",
			"urgency": "Normal"
		},
		"sfx": {
		    "exec": "",
			"urgency": "Normal"
		}
	},
	"notification-visibility": {
		"notification-name": {}
	},
	"widgets": [
		"buttons-grid",
		"mpris",
		"volume",
		"title",
		"dnd",
		"notifications"
	],
	"widget-config": {
		"inhibitors": {
			"text": "Inhibitors",
			"button-text": "Clear All",
			"clear-all-button": true
		},
		"title": {
			"text": "Notifs",
			"clear-all-button": true,
			"button-text": "Clear"
		},
		"dnd": {
			"text": "DND"
		},
		"label": {
			"max-lines": 5,
			"text": "Label Text"
		},
		"mpris": {
			"image-size": 96,
			"image-radius": 12
		},
		"volume": {
			"label": "ó°•¾",
			"expand-button-label": "ïƒ˜",
			"collapse-button-label": "ïƒ—",
			"show-per-app": true
		},
		"backlight": {
			"label": "ó°ƒŸ ",
			"subsystem": "leds",
			"device": "input19::compose"
		},
		"menubar": {
			"menu#power":{
				"label": "power",
				"actions": [
					{
						"label": "ï€‘   Shut down",
						"command": "systemctl poweroff"
					},
					{
						"label": "ï€¡   Reboot",
						"command": "systemctl reboot"
					},
					{
						"label": "ó°Œ¾   Lock",
						"command": "swaylock.sh"
					},
					{
						"label": "ï††   Sleep",
						"command": "loginctl terminate-session ${XDG_SESSION_ID-}"
					},
					{
						"label": "ï‚‹   Logout",
						"command": "loginctl terminate-session ${XDG_SESSION_ID-}"
					}
				]
			}
			
		},
		"buttons-grid": {
			"actions": [
				{
					"label": "ï€‘",
					"command": "systemctl poweroff"
				},
				{
					"label": "ï€¡",
					"command": "systemctl reboot"
				},
				{
					"label": "ó°Œ¾",
					"command": "swaylock.sh"
				},
				{
					"label": "ï††",
					"command": "loginctl terminate-session ${XDG_SESSION_ID-}"
				},
				{
					"label": "ï‚‹",
					"command": "loginctl terminate-session ${XDG_SESSION_ID-}"
				}

			]
		}
	}
}
