(defwindow dashboard
    :monitor 0
    :geometry (geometry :x "0"
                        :y "0"
                        :anchor "center")
    :stacking "fg"
    :exclusive "false"
    :focusable "true"
    ; :windowtype "dock"
    ; :wm-ignore true
(dashboard))
