{
    "layer": "top", // Waybar at top layer
    "position": "left", // Waybar position (top|bottom|left|right)
    //"height": , // Waybar height (to be removed for auto height)
    "width": 40, // Waybar width
    "spacing": 10, // Gaps between modules (4px)
    "margin-left":8,
    "margin-right":0,
    "margin-top":19,
    "margin-bottom":19,

    // Choose the order of the modules
    "modules-left": ["wlr/workspaces" ],
    "modules-center": [ "cava" ], 
    "modules-right": [ "pulseaudio", "clock", "custom/dunst", "tray","battery","custom/powermenu"],
    // Modules configuration
     "wlr/workspaces": {
         "all-outputs": true,
         "format": "{icon}",
         "format-icons": {
             "1": "пМГ",
             "2": "пЗЉ",
             "3": "оЯЕ",
             "4": "у∞Н°",
             "5": "пЙ©",
             "6": "пДЫ",
             "7": "пДМ",
             "8": "пДМ",
             "9": "пДМ",
             "0": "пДЙ",
             "urgent": "пБ™",
             "focused": "пДС",
             "default": "пДМ",
         },
       "on-scroll-up": "hyprctl dispatch workspace e+1",
       "on-scroll-down": "hyprctl dispatch workspace e-1",
       "on-click": "activate",
       },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": " {name} {icon}",
        "format-icons": {
            "locked": "пА£",
            "unlocked": "пВЬ"
        }
    },
    "hyprland/window": {
      "format": "рЯСЙ {}",
      "separate-outputs": true,
    },
    "mpd": {
		"rotate":90,
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) вЄ®{songPosition}|{queueLength}вЄ© {volume}% пАБ",
        "format-disconnected": "Disconnected пАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped пАБ",
        "unknown-tag": "N/A",
        "title-len" : 10,
        "interval": 2,
        "consume-icons": {
            "on": "пГД "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">пБі</span> ",
            "on": "пБі "
        },
        "repeat-icons": {
            "on": "пАЮ "
        },
        "single-icons": {
            "on": "пАЮ1 "
        },
        "state-icons": {
            "paused": "пБМ",
            "playing": "пБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пБЃ",
            "deactivated": "пБ∞"
        }
    },
    "tray": {
        "show-passive-items" : true,
         "icon-size": 20,
        "spacing": 12
    },
    "clock": {
        //"timezone": "Brazil/Sao_Paulo",
		"interval": 60,
        "format": "{:%H\n..\n%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
		    "calendar": {
                "mode"          : "month",
                "on-scroll"     : 1,
                "on-click-right": "mode",
                "format": {
                        "months":     "<span color='#dbcfe0'>{}</span>",
                        "days":       "<span color='#dbcfe0'>{}</span>",
                        "weeks":      "<span color='#e3a7d6'>W{}</span>",
                        "weekdays":   "<span color='#c4b0dd'>{}</span>",
                        "today":      "<span color='#c0c9ff'><b>{}</b></span>"
                          }
                }
		},
    "cpu": {
        "format": "{usage}%\n пЛЫ",
        "tooltip": false
    },
    "memory": {
        "format": "{}%\n пГЙ"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}¬∞C {icon}",
        "format": "{temperatureC}¬∞C {icon}",
        "format-icons": ["пЭЂ", "пЛЙ", "пЭ©"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
    },
    "battery": {
        "interval": 60,
        "format": "{icon}",
        "format-icons": ["пЦН", "пХЇ", "пХљ", "пХњ", "пХЄ"],
        "tooltip-format": "{capacity}%",
        "max-length": 25
    },
        "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) пЗЂ",
        "format-ethernet": "{ipaddr}/{cidr} пЮЦ",
        "tooltip-format": "{ifname} via {gwaddr} пЮЦ",
        "format-linked": "{ifname} (No IP) пЮЦ",
        "format-disconnected": "Disconnected вЪ†",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}\n<span size='xx-large'>{icon}</span>{format_source}",
        "format-bluetooth": "{volume}% {icon}пКФ{format_source}",
        "format-bluetooth-muted": "пЪ©{icon}пКФ{format_source}",
        "format-muted": "off\n<span size='xx-large'>у∞ЭЯ{format_source}</span>",
        "format-source-muted": "\n <span size='x-large'>пД±</span>",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "пЦР",
            "headset": "пЦР",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА¶", "пАІ", "у∞ХЊ"]
        },
        "on-click-right": "pavucontrol",
        "on-click-middle" : "pulseaudio-control --node-blacklist 'alsa_output.pci-0000_01_00.1.hdmi-stereo-extra2' next-node",
        "on-click":"pulseaudio-control togmute",
    },
    "custom/dunst": {
        "format": "{}<span size='xx-large'>\n{icon}</span>",
        "on-click": " $HOME/.config/waybar/show-not-history.sh",
        "on-click-right": "dunstctl close-all",
        "exec" : "dunstctl count history",
        "restart-interval": 1,
        "format-icons":{
          "default": "у∞ВЪ"
        },
    },
    "custom/powermenu": {
      "format": "<span size='xx-large'>{icon}</span>{}",
      "on-click": " $HOME/.config/rofi/powermenu/powermenu.sh",
      "format-icons":{
        "default": "вПї"
      },
    },
	"cava": {
        "cava_config": "/home/traveler/.config/cava/config",
		"method": "pipewire",
        "source": "auto",
		"bars": 14,
		"sensitivity": 100,
		"format-icons" : ["вЦБ", "вЦВ", "вЦГ", "вЦД", "вЦЕ", "вЦЖ", "вЦЗ", "вЦИ" ],
        "actions": {
                   "on-click-right": "mode"
                   },
    },
}
