# Zathura configuration file
# See man `man zathurarc'

# Open document in fit-width mode by default
set adjust-open "best-fit"

# One page per row by default
set pages-per-row 1

#stop at page boundries
set scroll-page-aware "true"
set smooth-scroll "true"
set scroll-full-overlap 0.01
set scroll-step 100

#zoom settings
set zoom-min 10
set guioptions ""

# zathurarc-dark

set font "inconsolata 15"

set default-bg "#191f65" #00
set default-fg "#DFF5DB" #01

set statusbar-fg "#DFF5DB" #04
set statusbar-bg "#222b8d" #01

set inputbar-bg "#191f65" #00 currently not used
set inputbar-fg "#DFF5DB" #02

set notification-error-bg "#AC4142" #08
set notification-error-fg "#191f65" #00

set notification-warning-bg "#AC4142" #08
set notification-warning-fg "#191f65" #00

set highlight-color "#F4BF75" #0A
set highlight-active-color "#6A9FB5" #0D

set completion-highlight-fg "#191f65" #02
set completion-highlight-bg "#90A959" #0C

set completion-bg "#303030" #02
set completion-fg "#E0E0E0" #0C

set notification-bg "#90A959" #0B
set notification-fg "#191f65" #00

set recolor "true"
set recolor-lightcolor "#DFF5DB" #00

set recolor-darkcolor "#191f65" #06
set recolor-reverse-video "true"
set recolor-keephue "true"

map <C-i> recolor

set render-loading "false"
set scroll-step 50
unmap f
map f toggle_fullscreen
map [fullscreen] f toggle_fullscreen
