# Zathura configuration file
# See man `man zathurarc'

# Open document in fit-width mode by default
set adjust-open "best-fit"

# One page per row by default
set pages-per-row 1

#stop at page boundries
set scroll-page-aware "true"
set smooth-scroll "true"
set scroll-full-overlap 0.01
set scroll-step 100

#zoom settings
set zoom-min 10
set guioptions ""

# zathurarc-dark

set font "inconsolata 15"

set default-bg rgba(34,26,43,1) #00
set default-fg "#dbcfe0" #01

set statusbar-fg "#dbcfe0" #04
set statusbar-bg rgba(34,26,43,1) #01

set inputbar-bg rgba(34,26,43,1) #00 currently not used
set inputbar-fg "#dbcfe0" #02

set notification-error-bg "#3a2c4a" #08
set notification-error-fg "#a7abdb" #00

set notification-warning-bg "#3a2c4a" #08
set notification-warning-fg "#a7abdb" #00

set highlight-color "#c19cc5" #0A
set highlight-active-color "#ffb3ff" #0D

set completion-highlight-fg "#a7abdb" #02
set completion-highlight-bg "#3a2c4a" #0C

set completion-bg "#3a2c4a" #02
set completion-fg "#dbcfe0" #0C

set notification-bg "#3a2c4a" #0B
set notification-fg "#dbcfe0" #00

set recolor "true"
set recolor-lightcolor rgba(34,26,43,1) #00

set recolor-darkcolor "#dbcfe0" #06
set recolor-reverse-video "true"
set recolor-keephue "true"

map <C-i> recolor

set render-loading "false"
set scroll-step 50
unmap f
map f toggle_fullscreen
map [fullscreen] f toggle_fullscreen
