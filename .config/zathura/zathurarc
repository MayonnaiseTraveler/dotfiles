# Zathura configuration file
# See man `man zathurarc'

# Open document in fit-width mode by default
set adjust-open "best-fit"

# One page per row by default
set pages-per-row 1

#stop at page boundries
set scroll-page-aware "true"
set smooth-scroll "true"
set scroll-full-overlap 0.01
set scroll-step 100

#zoom settings
set zoom-min 10
set guioptions ""

# zathurarc-dark

set font "inconsolata 15"

set default-bg rgba(3,8,29,1) #00
set default-fg "#ccced9" #01

set statusbar-fg "#ccced9" #04
set statusbar-bg rgba(3,8,29,1) #01

set inputbar-bg rgba(3,8,29,1) #00 currently not used
set inputbar-fg "#ccced9" #02

set notification-error-bg "#06134b" #08
set notification-error-fg "#f71a68" #00

set notification-warning-bg "#06134b" #08
set notification-warning-fg "#f71a68" #00

set highlight-color "#2854a3" #0A
set highlight-active-color "#2669e1" #0D

set completion-highlight-fg "#f71a68" #02
set completion-highlight-bg "#06134b" #0C

set completion-bg "#06134b" #02
set completion-fg "#ccced9" #0C

set notification-bg "#06134b" #0B
set notification-fg "#ccced9" #00

set recolor "true"
set recolor-lightcolor rgba(3,8,29,1) #00

set recolor-darkcolor "#ccced9" #06
set recolor-reverse-video "true"
set recolor-keephue "true"

map <C-i> recolor

set render-loading "false"
set scroll-step 50
unmap f
map f toggle_fullscreen
map [fullscreen] f toggle_fullscreen
